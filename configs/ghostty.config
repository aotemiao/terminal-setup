
theme = Catppuccin Mocha
font-family = MesloLGS NF
font-size = 14

# macOS: let Option behave as Alt for terminal apps such as Zellij.
macos-option-as-alt = true

# Ghostty's macOS defaults bind these to word navigation. Unbind them so
# Zellij can receive Alt+Left/Right for pane focus movement.
keybind = alt+left=unbind
keybind = alt+right=unbind

# 窗口
window-padding-x = 12
window-padding-y = 8
